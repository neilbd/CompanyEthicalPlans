NODE_ENV=development
PORT=3000
CLAUDE_VERSION=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=<your-api-key-here>
MAX_TOKENS=1024
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB (local via docker-compose, or a connection string)
MONGODB_URI=mongodb://localhost:27017/ethicalplans

# Session signing secret (use a long random value)
SESSION_SECRET=<your-session-secret>

# AWS S3 (stores analysis result blobs)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
S3_BUCKET_NAME=<your-s3-bucket-name>
# Optional: point at MinIO/LocalStack instead of real S3 (leave unset for AWS)
# S3_ENDPOINT=http://localhost:9000
